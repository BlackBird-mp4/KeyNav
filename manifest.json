{
  "manifest_version": 2,
  "name": "KeyNav",
  "version": "1.0.0",
  "description": "Navigate any website with keyboard letter hints. Fast, customizable, and mouse-free browsing.",
  "author": "KeyNav",
  "homepage_url": "https://github.com/BlackBird-mp4/KeyNav",
  
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },

  "permissions": [
    "activeTab",
    "storage"
  ],

  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.svg"
    },
    "default_title": "KeyNav",
    "default_popup": "popup/popup.html"
  },

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "commands": {
    "toggle-hints": {
      "suggested_key": {
        "default": "Alt+J"
      },
      "description": "Show/hide link hints"
    },
    "toggle-hints-newtab": {
      "suggested_key": {
        "default": "Alt+K"
      },
      "description": "Show hints (open in new tab)"
    }
  }
}
